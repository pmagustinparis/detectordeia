{
  "crons": [
    {
      "path": "/api/cron/send-lead-emails",
      "schedule": "0 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/admin/analytics-v2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
